DATABASE_URL=sqlite+aiosqlite:///./revenue_agent.db
SECRET_KEY=your-secret-key
ENVIRONMENT=development
AI_PLATFORM_URL=https://your-shared-ai-platform.azurewebsites.net
AI_PLATFORM_API_KEY=your-internal-app-key
AI_REQUIRE_APP_KEY=true
AI_TIMEOUT_MS=60000

# Email (for outreach)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password

# Remotive API (free)
REMOTIVE_API_URL=https://remotive.com/api/remote-jobs

# LinkedIn (manual mode only)
LINKEDIN_PROFILE_URL=https://linkedin.com/in/your-profile

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Optional: use Postgres in production if you have one provisioned
# DATABASE_URL=postgresql+asyncpg://postgres:password@host:5432/revenue_agent
